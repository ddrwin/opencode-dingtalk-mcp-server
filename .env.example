# 钉钉应用凭证（请替换为你的实际凭证）
DINGTALK_CLIENT_ID=your_client_id_here
DINGTALK_CLIENT_SECRET=your_client_secret_here

# OpenCode 服务器地址
OPENCODE_SERVER_URL=http://127.0.0.1:4096

# DeepSeek AI 自动回复（必填，否则无法自动回复）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DeepSeek 模型（可选，默认 deepseek-chat）
# DEEPSEEK_MODEL=deepseek-chat

# 共享身份文档路径（指向你的 identity/memory 目录，与本项目共享同一套文档）
# 支持指向 memory/ 或工程哲学/ 目录，所有 AI 分身读同一套
DOCUMENTS_PATH=
# 核心文档列表，逗号分隔，按优先级排序（留空=用默认列表）
# 默认: IDENTITY V0.2.md,工程哲学 V3.3.md,纪律手册 V3.3.md,AGENTS V3.3.md,VISION.md
# DOCUMENTS_CORE=
# 会话记忆存储路径（默认 ./sessions）
# SESSIONS_PATH=

# 日志级别 (debug, info, warn, error)
LOG_LEVEL=info
